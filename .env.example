# 复制为项目根目录 .env 后按需修改
DATABASE_URL=postgres://basketball:basketball@127.0.0.1:5433/basketball

JWT_ACCESS_SECRET=change-me-to-long-random-string
JWT_REFRESH_SECRET=change-me-another-long-random-string

# 分享页链接前缀（生产: https://basketball.itorange.online）
PUBLIC_APP_URL=http://localhost:5173

# API 监听（开发本机，生产可 127.0.0.1:3001 由 Nginx 反代）
PORT=3001
HOST=0.0.0.0
